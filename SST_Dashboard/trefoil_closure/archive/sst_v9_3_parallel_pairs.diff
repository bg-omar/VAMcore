+def _worker_geom_token(N_geom: int, N_int_target: int, R_ratio: Optional[float]) -> str:
+    if R_ratio is None:
+        return f"{int(N_geom)}:{int(N_int_target)}"
+    return f"{int(N_geom)}:{int(N_int_target)}:{float(R_ratio):.12g}"
+
+
+def _parse_worker_geom_token(token: str) -> Tuple[int, int, Optional[float]]:
+    parts = [p.strip() for p in str(token).split(":") if p.strip()]
+    if len(parts) == 2:
+        return int(parts[0]), int(parts[1]), None
+    if len(parts) == 3:
+        return int(parts[0]), int(parts[1]), float(parts[2])
+    raise ValueError(f"Invalid worker geom token: {token!r}")
+
+
+def _collect_csv_rows(path: str) -> List[dict]:
+    if not os.path.exists(path):
+        return []
+    try:
+        df = pd.read_csv(path)
+    except Exception:
+        return []
+    return df.to_dict(orient="records")
+
+
+def _merge_parallel_worker_outputs(child_dirs: List[str], mode: str) -> Tuple[List[dict], List[dict], List[dict]]:
+    rows: List[dict] = []
+    postcheck_rows: List[dict] = []
+    plateau_rows: List[dict] = []
+    summary_name = f"robustness_summary_v9_{mode}.csv"
+    for child_dir in child_dirs:
+        rows.extend(_collect_csv_rows(os.path.join(child_dir, summary_name)))
+        postcheck_rows.extend(_collect_csv_rows(os.path.join(child_dir, "shiftfree_postcheck_v9_3.csv")))
+        plateau_rows.extend(_collect_csv_rows(os.path.join(child_dir, "plateau_mask_diagnostics_v9_3.csv")))
+    return rows, postcheck_rows, plateau_rows
+
+
+def _build_child_argv(args: argparse.Namespace, geom_token: str, child_outdir: str) -> List[str]:
+    argv = [
+        sys.executable,
+        os.path.abspath(__file__),
+        "--mode", str(args.mode),
+        "--preset", str(args.preset),
+        "--backend", str(args.backend),
+        "--contact-model", str(args.contact_model),
+        "--root-selection-mode", str(args.root_selection_mode),
+        "--run-v6-shiftfree-postcheck", str(int(bool(args.run_v6_shiftfree_postcheck))),
+        "--emit-v5-logs", str(int(bool(args.emit_v5_logs))),
+        "--branch-mode", str(args.branch_mode),
+        "--extrap-min-nint", str(int(args.extrap_min_nint)),
+        "--sweep-layout", "exact_pairs_only",
+        "--worker-geom-config", geom_token,
+        "--output-dir", child_outdir,
+        "--pair-workers", "1",
+        "--no-auto-compile",
+    ]
+    if getattr(args, "knot_id", None) is not None:
+        argv += ["--knot-id", str(args.knot_id)]
+    if getattr(args, "max_fourier_mode", None) is not None:
+        argv += ["--max-fourier-mode", str(args.max_fourier_mode)]
+    if getattr(args, "n_geom_list", ""):
+        argv += ["--n-geom-list", str(args.n_geom_list)]
+    if getattr(args, "n_int_list", ""):
+        argv += ["--n-int-list", str(args.n_int_list)]
+    if getattr(args, "lambda_list", ""):
+        argv += ["--lambda-list", str(args.lambda_list)]
+    if getattr(args, "plateau_fracs", ""):
+        argv += ["--plateau-fracs", str(args.plateau_fracs)]
+    if getattr(args, "no_torch", False):
+        argv.append("--no-torch")
+    if getattr(args, "no_local_sst_core", False):
+        argv.append("--no-local-sst-core")
+    if getattr(args, "no_v8_extrapolation", False):
+        argv.append("--no-v8-extrapolation")
+    return argv
+
+
+def _run_parallel_pairs(args: argparse.Namespace, geom_configs: List[Tuple[int, int, Optional[float]]], output_dir: str) -> Tuple[List[dict], List[dict], List[dict]]:
+    pair_workers = max(1, int(getattr(args, "pair_workers", 1)))
+    child_root = os.path.join(output_dir, "parallel_pair_workers_v9_3")
+    os.makedirs(child_root, exist_ok=True)
+
+    child_jobs = []
+    for idx, (N_geom, N_int_target, R_ratio) in enumerate(geom_configs):
+        geom_token = _worker_geom_token(N_geom, N_int_target, R_ratio)
+        safe_token = geom_token.replace(":", "_")
+        child_outdir = os.path.join(child_root, f"pair_{idx:03d}_{safe_token}")
+        os.makedirs(child_outdir, exist_ok=True)
+        child_jobs.append((geom_token, child_outdir, _build_child_argv(args, geom_token, child_outdir)))
+
+    print(f"[PAR] pair_workers={pair_workers} total_pairs={len(child_jobs)} child_root={child_root}")
+
+    env = os.environ.copy()
+    env.setdefault("OMP_NUM_THREADS", "1")
+    env.setdefault("OPENBLAS_NUM_THREADS", "1")
+    env.setdefault("MKL_NUM_THREADS", "1")
+    env.setdefault("NUMEXPR_NUM_THREADS", "1")
+
+    failures: List[str] = []
+    running: List[Tuple[subprocess.Popen, str, str]] = []
+    pending = list(child_jobs)
+
+    while pending or running:
+        while pending and len(running) < pair_workers:
+            geom_token, child_outdir, argv = pending.pop(0)
+            print(f"[PAR] launch geom={geom_token} -> {child_outdir}")
+            proc = subprocess.Popen(argv, env=env)
+            running.append((proc, geom_token, child_outdir))
+
+        next_running: List[Tuple[subprocess.Popen, str, str]] = []
+        for proc, geom_token, child_outdir in running:
+            ret = proc.poll()
+            if ret is None:
+                next_running.append((proc, geom_token, child_outdir))
+                continue
+            if ret != 0:
+                failures.append(f"geom={geom_token} exit={ret} outdir={child_outdir}")
+            else:
+                print(f"[PAR] done geom={geom_token}")
+        running = next_running
+        if running:
+            time.sleep(0.5)
+
+    if failures:
+        raise RuntimeError("Parallel pair workers failed:\n" + "\n".join(failures))
+
+    child_dirs = [child_outdir for _, child_outdir, _ in child_jobs]
+    rows, postcheck_rows, plateau_rows = _merge_parallel_worker_outputs(child_dirs, str(args.mode))
+    print(f"[PAR] merged rows={len(rows)} postcheck_rows={len(postcheck_rows)} plateau_rows={len(plateau_rows)}")
+    return rows, postcheck_rows, plateau_rows
+
