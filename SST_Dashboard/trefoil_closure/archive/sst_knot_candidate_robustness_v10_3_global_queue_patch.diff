+def _should_parallelize_global_batch(task_count: int, knot_count: int) -> bool:
+    scope = str(PARALLEL_SCOPE).lower()
+    if knot_count <= 1:
+        return False
+    if scope in ("none", "geom"):
+        return False
+    if task_count < AUTO_PARALLEL_MIN_TASKS:
+        return False
+    if scope in ("global", "auto"):
+        return _resolved_worker_count(task_count) > 1
+    return False
