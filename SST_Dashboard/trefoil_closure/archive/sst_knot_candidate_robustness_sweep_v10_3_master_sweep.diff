+def write_master_batch_archives(knot_records: List[dict], base_output_dir: str) -> None:
+    if not WRITE_MASTER_BATCH_ARCHIVE or not knot_records:
+        return
+    archive_specs = [
+        ("robustness_summary_csv", os.path.join(base_output_dir, "master_robustness_archive_v10_3.csv")),
+        ("plateau_diagnostics_csv", os.path.join(base_output_dir, "master_plateau_archive_v10_3.csv")),
+        ("postcheck_csv", os.path.join(base_output_dir, "master_postcheck_archive_v10_3.csv")),
+        ("raw_scan_archive_csv", os.path.join(base_output_dir, "master_raw_scan_curve_archive_v10_3.csv")),
+        ("root_candidate_archive_csv", os.path.join(base_output_dir, "master_root_candidate_archive_v10_3.csv")),
+    ]
+    archive_counts: Dict[str, int] = {}
+    for key, outpath in archive_specs:
+        frames = []
+        for rec in knot_records:
+            path = rec.get(key)
+            if path and os.path.isfile(path):
+                try:
+                    frames.append(pd.read_csv(path))
+                except Exception as exc:
+                    print(f"[WARN] Could not read {path} for master archive {os.path.basename(outpath)}: {exc}")
+        if frames:
+            df = pd.concat(frames, ignore_index=True, sort=False)
+            df.to_csv(outpath, index=False)
+            archive_counts[os.path.basename(outpath)] = int(len(df))
+            print(f"[META] Master archive written: {outpath} ({len(df)} rows)")
+    manifest = {
+        "script_version": SCRIPT_VERSION,
+        "created_wall": time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime(time.time())),
+        "base_output_dir": base_output_dir,
+        "knot_count": len(knot_records),
+        "knot_records": knot_records,
+        "archive_row_counts": archive_counts,
+    }
+    manifest_path = os.path.join(base_output_dir, "master_batch_manifest_v10_3.json")
+    with open(manifest_path, "w", encoding="utf-8") as f:
+        json.dump(manifest, f, indent=2, ensure_ascii=False)
+    print(f"[META] Master batch manifest: {manifest_path}")
+
