+def build_scan_curve_rows(knot_id: str, mode: str, N_geom: int, N_int_target: int, geom: GeometryData, R_ratio: Optional[float],
+                          ideal_source_str: str, backend_this: str, a_scan: np.ndarray, E_vals: np.ndarray) -> List[dict]:
+    rows: List[dict] = []
+    for idx, (a_val, e_val) in enumerate(zip(a_scan, E_vals)):
+        rows.append({
+            "knot_id": knot_id, "mode": mode,
+            "N_geom": N_geom, "N_int_target": N_int_target, "N_int_actual": int(geom.N_int_actual),
+            "R_t_over_r_t": R_ratio if R_ratio is not None else np.nan,
+            "L_dimless": float(geom.L_dimless_full), "d_min_dimless": float(geom.d_min_full),
+            "scan_idx": idx,
+            "a_scan_m": float(a_val), "a_scan_over_rc": float(a_val / r_c_canon),
+            "E_scan_J": float(e_val),
+            "ideal_source": ideal_source_str, "bs_backend": backend_this,
+        })
+    return rows
+
+
+
+def build_root_candidate_rows(knot_id: str, mode: str, N_geom: int, N_int_target: int, geom: GeometryData, R_ratio: Optional[float],
+                              ideal_source_str: str, backend_this: str, fr: FitResult, lam_K: float, p_exp: int,
+                              candidates: List[RootCandidate], selected_a_star: float, selected_root_choice: str,
+                              x_closure: float) -> List[dict]:
+    rows: List[dict] = []
+    selected_idx = -1
+    if np.isfinite(selected_a_star):
+        for cand_idx, cand in enumerate(candidates):
+            if np.isfinite(cand.a_star) and abs(cand.a_star - selected_a_star) <= max(1e-30, 1e-12 * max(abs(selected_a_star), 1.0)):
+                selected_idx = cand_idx
+                break
+    for cand_idx, cand in enumerate(candidates):
+        a_over_rc = cand.a_star / r_c_canon if np.isfinite(cand.a_star) else np.nan
+        rows.append({
+            "knot_id": knot_id, "mode": mode,
+            "N_geom": N_geom, "N_int_target": N_int_target, "N_int_actual": int(geom.N_int_actual),
+            "R_t_over_r_t": R_ratio if R_ratio is not None else np.nan,
+            "L_dimless": float(geom.L_dimless_full), "d_min_dimless": float(geom.d_min_full),
+            "fit_method": fr.fit_method, "plateau_frac": fr.plateau_frac, "n_plateau": fr.n_plateau,
+            "A_K": float(fr.A_K), "A_ratio": float(fr.A_K / A_req) if np.isfinite(fr.A_K) else np.nan, "a_K": float(fr.a_K),
+            "closure_x_from_A": float(x_closure),
+            "lambda_K": float(lam_K), "p_exp": int(p_exp),
+            "candidate_index": cand_idx, "candidate_count": len(candidates),
+            "candidate_selected": bool(cand_idx == selected_idx), "selected_root_choice": selected_root_choice,
+            "candidate_is_min": bool(cand.is_min),
+            "a_candidate_m": float(cand.a_star), "a_candidate_over_rc": float(a_over_rc),
+            "E_candidate_J": float(cand.E_star),
+            "ideal_source": ideal_source_str, "bs_backend": backend_this,
+        })
+    return rows
+
+
