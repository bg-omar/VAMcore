+def _resolved_worker_count(task_count: int) -> int:
+    if task_count <= 0:
+        return 1
+    if MAX_WORKERS and MAX_WORKERS > 0:
+        return max(1, min(int(MAX_WORKERS), task_count))
+    cpu_n = os.cpu_count() or 1
+    return max(1, min(task_count, max(1, cpu_n - 1)))
+
+
+def _should_parallelize_geom(task_count: int) -> bool:
+    scope = str(PARALLEL_SCOPE).lower()
+    if scope == "none":
+        return False
+    if task_count < AUTO_PARALLEL_MIN_TASKS:
+        return False
+    if scope == "geom":
+        return _resolved_worker_count(task_count) > 1
+    if scope == "auto":
+        return _resolved_worker_count(task_count) > 1
+    return False
+
